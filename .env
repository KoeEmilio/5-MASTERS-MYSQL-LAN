# ============================================================
#  .env — Variables de Entorno para Anillo de 6 Nodos
#  Copiar a .env y ajustar las IPs a tu red LAN.
# ============================================================

# --- IPs de la Red LAN (una por cada PC física) ---
NODE1_IP=192.168.254.75
NODE2_IP=192.168.137.32
NODE3_IP=192.168.137.34
NODE4_IP=192.168.137.101
NODE5_IP=192.168.137.95
NODE6_IP=192.168.137.100

# --- Puerto MySQL (mismo en todos los nodos) ---
MYSQL_PORT=3306

# --- Credenciales MySQL ---
MYSQL_ROOT_PASSWORD=rootpassword

# --- Usuario Administrador para conexión remota LAN ---
# (root permanece restringido a localhost por seguridad)
ADMIN_USER=admin_lan
ADMIN_PASSWORD=admin_secure_pass

# --- Usuario de Replicación ---
REPL_USER=replicator
REPL_PASSWORD=replpassword
